{
  "permissions": {
    "allow": [
      "Bash(.venv/bin/python:*)",
      "Bash(.venv/bin/python -m pytest:*)",
      "Bash(.venv/bin/python -m sphinx:*)",
      "Bash(.venv/bin/python -m pip:*)",
      "Bash(.venv/bin/python -m derivations:*)",
      "Bash(.venv/bin/nexus:*)",
      "Bash(gh issue:*)",
      "Bash(gh label:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",
      "Bash(gh search:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git stash:*)",
      "Bash(git remote:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(open:*)",
      "Bash(timeout:*)",
      "Bash(MPLBACKEND=Agg:*)",
      "Write(.claude/agents/**)",
      "Edit(.claude/agents/**)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:en.wikipedia.org)",
      "WebFetch(domain:www.osti.gov)",
      "WebFetch(domain:www.semanticscholar.org)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:link.springer.com)",
      "WebFetch(domain:www.researchgate.net)",
      "WebFetch(domain:www.mdpi.com)",
      "WebFetch(domain:digital.library.unt.edu)",
      "WebFetch(domain:open-sn.github.io)",
      "WebFetch(domain:people.bath.ac.uk)",
      "mcp__nexus__query",
      "mcp__nexus__context",
      "mcp__nexus__neighbors",
      "mcp__nexus__impact",
      "mcp__nexus__detect_changes",
      "mcp__nexus__retest",
      "mcp__nexus__trace_error",
      "mcp__nexus__session_briefing",
      "mcp__nexus__staleness",
      "mcp__nexus__verification_coverage",
      "mcp__nexus__communities",
      "mcp__nexus__bridges",
      "mcp__nexus__god_nodes",
      "mcp__nexus__processes",
      "mcp__nexus__provenance_chain",
      "mcp__nexus__shortest_path",
      "mcp__nexus__graph_query",
      "mcp__nexus__rename",
      "mcp__nexus__migration_plan",
      "mcp__nexus__stats",
      "mcp__nexus__ingest"
    ],
    "deny": [
      "Bash(python :*)",
      "Bash(python3 :*)",
      "Bash(python -:*)",
      "Bash(python3 -:*)",
      "Bash(pip :*)",
      "Bash(pip3 :*)",
      "Bash(pip install:*)",
      "Bash(conda:*)",
      "Bash(mamba:*)",
      "Agent(Explore)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | grep -qE '^(python3?|pip3?) ' && echo '{\"decision\":\"block\",\"reason\":\"BLOCKED: Use .venv/bin/python instead of bare python/python3. Use .venv/bin/python -m pip instead of bare pip.\"}' || true",
            "timeout": 2000
          }
        ]
      }
    ]
  }
}
